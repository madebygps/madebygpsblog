---
type Props = {
  title: string;
  description?: string;
};

const { title, description = 'A minimal Astro blog hosted on Azure Static Web Apps.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style is:global>
      :root {
        color-scheme: light;
        --background: #f8fafc;
        --surface: #ffffff;
        --surface-muted: #eef2f7;
        --text: #18181b;
        --muted: #5f6673;
        --accent: #b42318;
        --accent-strong: #7a271a;
        --border: #d8dee8;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background: var(--background);
        color: var(--text);
        line-height: 1.65;
      }

      a {
        color: var(--accent);
        text-decoration-thickness: 0.12em;
        text-underline-offset: 0.2em;
      }

      header,
      main,
      footer {
        width: min(100% - 2rem, 840px);
        margin-inline: auto;
      }

      header {
        padding: 1.25rem 0;
      }

      .site-nav {
        display: flex;
        gap: 1rem;
        align-items: center;
        justify-content: space-between;
      }

      .site-nav a {
        color: var(--text);
        font-weight: 700;
        text-decoration: none;
      }

      .site-nav a:hover,
      .site-nav a:focus-visible {
        color: var(--accent);
      }

      .nav-links,
      .social-links {
        display: flex;
        align-items: center;
        gap: 0.85rem;
      }

      .nav-links {
        flex-wrap: wrap;
        justify-content: flex-end;
      }

      .social-links {
        border-left: 1px solid var(--border);
        padding-left: 0.85rem;
      }

      .social-links a {
        color: var(--muted);
      }

      main {
        padding: 1rem 0 4rem;
      }

      footer {
        border-top: 1px solid var(--border);
        color: var(--muted);
        padding: 1.5rem 0 2rem;
      }

      h1,
      h2,
      h3 {
        line-height: 1.15;
      }

      h1 {
        max-width: 20ch;
        font-size: 3.25rem;
        letter-spacing: 0;
        margin: 0 0 1rem;
      }

      .intro h1 {
        max-width: 19ch;
      }

      h2 {
        font-size: 1.45rem;
        margin: 2.25rem 0 0.75rem;
      }

      h3 {
        font-size: 1rem;
        margin: 0;
      }

      p {
        max-width: 68ch;
      }

      .eyebrow {
        color: var(--accent-strong);
        font-size: 0.85rem;
        font-weight: 800;
        letter-spacing: 0;
        margin: 0 0 0.75rem;
        text-transform: uppercase;
      }

      .lede {
        color: var(--muted);
        font-size: 1.08rem;
        max-width: 58ch;
      }

      .intro {
        padding: 1.5rem 0 1.25rem;
      }

      .about-intro {
        padding-top: 0.75rem;
      }

      .about-intro h1 {
        font-size: 2.6rem;
      }

      .about-intro .lede {
        font-size: 1rem;
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 1.5rem;
      }

      .button {
        align-items: center;
        background: var(--accent);
        border: 1px solid var(--accent);
        border-radius: 0.5rem;
        color: #fff;
        display: inline-flex;
        font-weight: 800;
        justify-content: center;
        min-height: 2.75rem;
        padding: 0.55rem 0.9rem;
        text-decoration: none;
      }

      .button:hover,
      .button:focus-visible {
        background: var(--accent-strong);
        border-color: var(--accent-strong);
      }

      .button.secondary {
        background: transparent;
        color: var(--accent-strong);
      }

      .button.secondary:hover,
      .button.secondary:focus-visible {
        background: var(--surface-muted);
        color: var(--accent-strong);
      }

      .about-section {
        border-top: 1px solid var(--border);
        padding-top: 1.75rem;
      }

      .link-list {
        display: grid;
        gap: 0.45rem;
        margin: 1rem 0 0;
        padding-left: 1.25rem;
      }

      .resource-list {
        display: grid;
        gap: 0.75rem;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        margin-top: 1rem;
      }

      .resource-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 0.5rem;
        padding: 1rem;
      }

      .resource-card p {
        color: var(--muted);
        margin: 0.5rem 0 0;
      }

      .post-list {
        display: grid;
        gap: 1rem;
        list-style: none;
        margin-top: 1.5rem;
        padding: 0;
      }

      .post-card {
        border: 1px solid var(--border);
        border-radius: 0.5rem;
        background: var(--surface);
        padding: 1.25rem;
      }

      .post-card h2 {
        margin: 0 0 0.35rem;
      }

      .post-card h2 a {
        color: var(--text);
      }

      .post-card h2 a:hover,
      .post-card h2 a:focus-visible {
        color: var(--accent);
      }

      .post-card p,
      .post-meta {
        color: var(--muted);
        margin: 0;
      }

      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 1rem;
      }

      .tag-cloud {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        justify-content: flex-start;
        margin: 1.5rem 0 2rem;
      }

      .tag {
        align-items: center;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 999px;
        color: var(--muted);
        display: inline-flex;
        font-size: 0.85rem;
        gap: 0.35rem;
        padding: 0.15rem 0.6rem;
        text-decoration: none;
      }

      .tag:hover,
      .tag:focus-visible {
        border-color: var(--accent);
        color: var(--accent);
      }

      .tag span {
        color: var(--accent-strong);
        font-weight: 700;
      }

      article h1 {
        max-width: 42rem;
      }

      article > :not(.feature-image) {
        margin-left: auto;
        margin-right: auto;
        max-width: 42rem;
      }

      article pre {
        background: #18181b;
        border-radius: 0.5rem;
        color: #f8fafc;
        overflow-x: auto;
        padding: 1rem;
      }

      article code {
        font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
        font-size: 0.95em;
      }

      article table {
        border-collapse: collapse;
        display: block;
        overflow-x: auto;
        width: 100%;
      }

      article th,
      article td {
        border: 1px solid var(--border);
        padding: 0.5rem;
        text-align: left;
      }

      article figure {
        margin: 1.5rem auto;
      }

      article img {
        border-radius: 0.5rem;
        display: block;
        height: auto;
        margin-inline: auto;
        max-height: min(62vh, 520px);
        max-width: 100%;
        width: auto;
      }

      article :global(iframe) {
        aspect-ratio: 16 / 9;
        border: 0;
        border-radius: 0.5rem;
        height: auto;
        max-width: 100%;
        width: 100%;
      }

      .feature-image {
        display: block;
        margin: 2rem 0;
        max-height: 26rem;
        object-fit: cover;
        width: 100%;
      }

      @media (max-width: 640px) {
        .site-nav {
          align-items: flex-start;
          flex-direction: column;
        }

        .nav-links {
          justify-content: flex-start;
        }

        .social-links {
          border-left: 0;
          padding-left: 0;
        }

        h1 {
          font-size: 2.5rem;
        }

        .about-intro h1 {
          font-size: 2.15rem;
        }

        .resource-list {
          grid-template-columns: 1fr;
        }
      }
    </style>
    <script is:inline>
      document.addEventListener(
        'error',
        (event) => {
          const target = event.target;

          if (!(target instanceof HTMLImageElement)) {
            return;
          }

          const figure = target.closest('figure');

          if (figure) {
            figure.remove();
            return;
          }

          target.remove();
        },
        true
      );
    </script>
  </head>
  <body>
    <header>
      <nav class="site-nav" aria-label="Main navigation">
        <a href="/">madebygps</a>
        <div class="nav-links">
          <a href="/blog/">Blog</a>
          <a href="/about/">About</a>
          <div class="social-links" aria-label="Social links">
            <a href="https://x.com/madebygps" target="_blank" rel="me noopener noreferrer">X</a>
            <a href="https://www.linkedin.com/in/madebygps" target="_blank" rel="me noopener noreferrer">LinkedIn</a>
            <a href="https://www.youtube.com/madebygps" target="_blank" rel="me noopener noreferrer">YouTube</a>
          </div>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <small>Built with Astro and Azure Static Web Apps.</small>
    </footer>
  </body>
</html>
