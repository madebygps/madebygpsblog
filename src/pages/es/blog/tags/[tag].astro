---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import PostList from '../../../../components/PostList.astro';
import { getDisplayPosts, type BlogPost } from '../../../../i18n/posts';
import { tagSlug } from '../../../../lib/tags';
import { useTranslations, blogPath } from '../../../../i18n/utils';

export async function getStaticPaths() {
  const posts = await getDisplayPosts('es');
  const tagMap = new Map<string, { tag: string; posts: BlogPost[] }>();

  posts.forEach((post) => {
    post.data.tags.forEach((tag) => {
      const slug = tagSlug(tag);
      const tagGroup = tagMap.get(slug) ?? { tag, posts: [] };
      tagGroup.posts.push(post);
      tagMap.set(slug, tagGroup);
    });
  });

  return [...tagMap.entries()].map(([slug, tagGroup]) => ({
    params: { tag: slug },
    props: { tag: tagGroup.tag, posts: tagGroup.posts }
  }));
}

const { tag, posts } = Astro.props;
const lang = 'es' as const;
const t = useTranslations(lang);
---

<BaseLayout
  title={`${tag}`}
  description={`Entradas con la etiqueta ${tag}.`}
  lang={lang}
  altLangUrl={blogPath('en')}
>
  <p class="post-meta"><a href={blogPath(lang)}>{t('blog.allPosts')}</a></p>
  <h1>{tag}</h1>
  <p class="lede">
    {posts.length} {posts.length === 1 ? 'entrada' : 'entradas'} con la etiqueta {tag}.
  </p>
  <PostList lang={lang} posts={posts} />
</BaseLayout>
