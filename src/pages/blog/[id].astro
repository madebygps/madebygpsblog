---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostArticle from '../../components/PostArticle.astro';
import { postSlug, translationKeyFor } from '../../i18n/posts';
import { postPath, blogPath } from '../../i18n/utils';

export async function getStaticPaths() {
  const all = await getCollection('blog');
  const enPosts = all.filter((post) => post.data.lang === 'en');

  return enPosts.map((post) => {
    const key = translationKeyFor(post);
    const translated = all.find(
      (other) => other.data.lang === 'es' && translationKeyFor(other) === key
    );
    const altLangUrl = translated ? postPath('es', postSlug(translated)) : blogPath('es');

    return {
      params: { id: postSlug(post) },
      props: { post, altLangUrl }
    };
  });
}

const { post, altLangUrl } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  lang="en"
  altLangUrl={altLangUrl}
>
  <PostArticle lang="en" post={post}>
    <Content />
  </PostArticle>
</BaseLayout>
